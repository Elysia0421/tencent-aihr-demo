{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "tencent-aihr-demo",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build"
    }
  ],
  "outputDirectory": "dist",
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}